# Template for ha/secrets.yaml — copy to ha/secrets.yaml and fill in.
# The real file is gitignored. Deployed to /config/custom/inkplate/secrets.yaml
# on the HAOS VM (project-scoped; the global /config/secrets.yaml is never
# touched by deploy.sh). HA's !secret tag auto-resolves it from there.

# --- Weather providers ---
# OpenWeatherMap OneCall 3.0 — primary source for 0-60 min minutely
# precipitation (1-min resolution). MET.no remains primary for current
# conditions and hourly forecast (no key). Sign up at
# https://openweathermap.org/api ("One Call by Call" subscription;
# free tier gives 1000 calls/day). See
# ha/integrations/weather_nowcast_minutely.yaml.
openweathermap_api_key: "REPLACE_ME"

# --- Coordinates ---
# <your primary location> (home). Used by the primary weather entity and by sun/moon.
place_a_latitude: 0.0      # set to your primary location
place_a_longitude: 0.0     # set to your primary location
place_a_elevation: 0       # meters above sea level

# <your secondary location> (mountain house). Used by the secondary weather entity.
place_b_latitude: 0.0      # set to your secondary location
place_b_longitude: 0.0     # set to your secondary location
place_b_elevation: 0       # meters above sea level

# --- Anthropic API key (offline corpus / astro tooling) ---
# Used by `ha/scripts/generate_astro_event.py` and ad-hoc corpus-seed generation.
# Not used at runtime by the Night poetic-line generator (that path is
# pool-only since `add-night-text-clock-partials`). Leave blank if you
# don't use those tools.
anthropic_api_key: "REPLACE_ME"

# --- Renderer host ---
# Reachable from the HAOS VM over LAN. Host the TS renderer runs on (the Mac).
renderer_host: "renderer.local"
renderer_port: 8575

# --- Renderer input publisher token ---
# Shared secret HA sends as `Authorization: Bearer <token>` when POSTing to
# `/inputs/:name` on the renderer. Stored in pre-composed header form so
# HA's `!secret` tag substitutes it directly into the Authorization header
# (HA's YAML does not permit composing a string from `!secret` + a prefix).
# The renderer reads the bare token from the `RENDERER_INPUT_TOKEN` env var
# (see renderer/launchd/com.inkplate.renderer.plist).
# Generate the token: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Then store the HA side as: "Bearer <token>"
# The URLs themselves are plain LAN coordinates and live in
# ha/integrations/rest_commands.yaml — not here.
renderer_input_auth_header: "Bearer REPLACE_ME"

# --- Device wake ---
# Shared with firmware/include/secrets.h — the device publishes state to this broker.
mqtt_broker_host: "homeassistant.local"
mqtt_broker_port: 1883

# --- Operator notification target ---
# HA mobile-app notify service id for the operator's phone.
operator_notify_service: "mobile_app_operator_phone"

# --- Home Assistant long-lived access token ---
# Used by the Now-Playing album-art fetch when Sonos's entity_picture is a
# relative HA proxy URL (/api/media_player_proxy/...). Create via Profile →
# Security → Long-Lived Access Tokens. Leave blank if your Sonos integration
# always exposes absolute CDN URLs.
ha_long_lived_token: ""

# --- HA base URL (for resolving relative entity_picture URLs) ---
ha_base_url: "http://homeassistant.local:8123"

# --- Spotify Web API (Client Credentials flow) ---
# Used by the renderer to enrich Now-Playing tracks with composer / work /
# performer-role metadata for classical music. App-only flow — no user OAuth,
# no scopes. Create at https://developer.spotify.com/dashboard. Free tier is
# sufficient (rate-limited but heavily cached on the renderer side).
spotify_client_id: "REPLACE_ME"
spotify_client_secret: "REPLACE_ME"

# --- MusicBrainz politeness ---
# MB requires a User-Agent identifying the app + a contact (per their TOU).
# Format: "<app>/<version> ( <contact> )" — contact can be email or URL.
# Cached lookups by ISRC / work-MBID are stored on disk in renderer/cache/mb/.
musicbrainz_user_agent: "inkplate-fridge/0.1 ( REPLACE_ME )"
