# Binary content — managed via corpus/_manifest.json and restored from backup
corpus/images/*.jpg
corpus/images/*.jpeg
corpus/images/*.png
corpus/images/*.tif
corpus/images/*.tiff
corpus/images/*.webp

corpus/nocturne/*.jpg
corpus/nocturne/*.jpeg
corpus/nocturne/*.png
corpus/nocturne/*.tif
corpus/nocturne/*.tiff
corpus/nocturne/*.webp

# Personal-library tier — binaries AND body-file text bodies are git-ignored
corpus/personal_library/*.jpg
corpus/personal_library/*.jpeg
corpus/personal_library/*.png
corpus/personal_library/*.tif
corpus/personal_library/*.tiff
corpus/personal_library/*.webp
corpus/personal_library/*.body.*.txt

# Generated content — pairings and audits
pairings/
corpus/_staging/

# Home Assistant — real secrets and mutable state live only on the VM / operator machine
ha/secrets.yaml
ha/state/*
!ha/state/.gitkeep

# Node / Python
node_modules/
__pycache__/
*.pyc
.venv/
dist/
build/

# Renderer runtime inputs — mutated by HA publishers + scripts on every wake
renderer/inputs/*
!renderer/inputs/.gitkeep

# Pairing host-local state — triplet rotation epoch (depends on first-run date)
pairing/_state/

# Firmware dry-run PNG captures
firmware/test/out/

# macOS
.DS_Store

# Operator-specific runtime values — substituted into tracked templates
# at deploy/build time. NEVER commit. See local-overrides.env.example for
# the template.
local-overrides.env

# Operator's curated content — sidecars and triplets reflect the operator's
# personal taste and bibliography. Templates (EXAMPLE.yaml.template) and
# the README are tracked; everything else under these dirs is ignored so
# forks can build their own corpus.
corpus/personal_library/*.yaml
corpus/texts/*.yaml
corpus/images/*.yaml
corpus/_triplets/*.yaml
corpus/_audits/*.md
corpus/_audits/*.json
corpus/_caches/*
corpus/_manifest.json
!corpus/personal_library/EXAMPLE.yaml.template
!corpus/texts/EXAMPLE.yaml.template
!corpus/texts/EXAMPLE-BILINGUAL.yaml.template
!corpus/images/EXAMPLE.yaml.template
!corpus/_triplets/EXAMPLE.yaml.template

# Per-deployment runtime state for the daily rotation.
pairing/_state/triplet_epoch.json
corpus/_sources/

# Firmware build artifacts and clangd indices — regenerated locally,
# never committed.
firmware/.cache/
firmware/build_host/
firmware/.pio/

# Operator-fetched ephemerides for ha/scripts/generate_astro_event.py.
# DE421 is ~17 MB and freely re-downloadable from JPL; not tracked.
ha/data/

# Claude Code session lock — tooling-internal.
.claude/scheduled_tasks.lock

# OpenSpec change review artifacts. The HTML pages and `*-renders/`
# directories are produced by `corpus build-review-page` for operator
# eyeballing during a change; they're regenerable from the corpus + the
# script, and the rendered PNGs alone can run to tens of megabytes per
# change. The change folder's source-of-truth (proposal.md, design.md,
# tasks.md, specs/) stays tracked.
openspec/changes/**/*-review.html
openspec/changes/**/*-review-over*.html
openspec/changes/**/*-renders/
