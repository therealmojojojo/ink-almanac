# local-overrides.env — operator-specific values substituted into tracked
# templates at deploy/build time. Copy this file to `local-overrides.env`
# (gitignored) and fill in your real values. Never commit
# `local-overrides.env`.
#
# How it's consumed:
#   - ha/deploy.sh sources this file and runs `envsubst` over the HA
#     deploy tarball before sending it to the HAOS VM. Tracked YAML uses
#     ${PLACE_A_NAME} etc.; HA gets the substituted values.
#   - Shell scripts that need these values at runtime read them as
#     `${VAR:-fallback}` so the script works even without sourcing this
#     file (it falls back to an mDNS-style default).
#   - Firmware does not consume this file directly — `firmware/include/
#     secrets.h` is gitignored and operator-filled-once from
#     `secrets.h.example`. The values you put there overlap with this
#     file and need to stay in sync if you change them.

# --- Network ---------------------------------------------------------------
# LAN host of the always-on Mac/Linux box that runs the renderer.
# mDNS .local works on macOS networks; IP is faster and more reliable.
RENDERER_HOST=renderer.local

# LAN host of the HAOS VM (or the bare-metal Home Assistant install).
HA_HOST=homeassistant.local

# LAN host of the Zigbee2MQTT instance, if you have one. Used by the Sonos
# remote integration. Leave as the default if you don't run Z2M.
Z2M_HOST=zigbee2mqtt.local

# --- Weather locations ----------------------------------------------------
# Two locations the dashboard renders side-by-side on the Weather face.
# NAME = display string shown in the rendered PNG.
# SLUG = lowercase entity-id-safe identifier — the HA sensors are named
#        sensor.<SLUG>_temperature_c, sensor.<SLUG>_condition, etc.
PLACE_A_NAME=Place A
PLACE_A_SLUG=place_a

PLACE_B_NAME=Place B
PLACE_B_SLUG=place_b

# --- Operator-specific paths ----------------------------------------------
# Absolute path to this clone on your renderer host. Used by HA scripts
# that SSH from the HA VM to the renderer host and run pairing/publishers.
# The operator's username can usually be left at $USER on macOS / Linux.
INKPLATE_REPO=/path/to/your/clone
OPERATOR_USER=$USER
